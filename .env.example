# Variáveis de Ambiente - COPIAR PARA .env.local (NÃO COMMITAR)

# ===========================
# SUPABASE — Backend
# ===========================
# Anon key (segura para frontend - pública)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...sua-chave-aqui

# ===========================
# EXERCISEDB API — Via Edge Function
# ===========================
# Configurar APENAS no Supabase (Backend), NÃO no frontend
# Dashboard Supabase → Functions → get-exercise-gif → Settings → Secrets
RAPIDAPI_KEY=sua-chave-exercisedb-aqui
RAPIDAPI_HOST=exercisedb.p.rapidapi.com

# ===========================
# ANTHROPIC API — Via Edge Function
# ===========================
# Configurar no Supabase (Backend)
# Dashboard Supabase → Functions → chat-ai → Settings → Secrets
ANTHROPIC_API_KEY=sk-ant-...sua-chave-aqui
ANTHROPIC_MODEL=claude-3-haiku-20240307

# ===========================
# OPENAI API - Via Edge Function
# ===========================
# Configurar no Supabase (Backend), NUNCA no frontend
# Dashboard Supabase -> Functions -> chat-ai -> Settings -> Secrets
OPENAI_API_KEY=sk-...sua-chave-aqui
OPENAI_FAST_MODEL=gpt-5-mini
OPENAI_REASONING_MODEL=gpt-5

# Roteador inteligente do chat-ai
# Padrao: Anthropic responde perguntas simples; OpenAI responde perguntas padrao/complexas
AI_ROUTER_SIMPLE_PROVIDER=anthropic
AI_ROUTER_STANDARD_PROVIDER=openai
AI_ROUTER_COMPLEX_PROVIDER=openai

# ===========================
# DESENVOLVIMENTO
# ===========================
ENVIRONMENT=development
DEBUG=false
