# Variáveis de Ambiente - COPIAR PARA .env.local (NÃO COMMITAR)

# ===========================
# SUPABASE — Backend
# ===========================
# Anon key (segura para frontend - pública)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...sua-chave-aqui

# ===========================
# EXERCISEDB API — Via Edge Function
# ===========================
# Configurar APENAS no Supabase (Backend), NÃO no frontend
# Dashboard Supabase → Functions → get-exercise-gif → Settings → Secrets
RAPIDAPI_KEY=sua-chave-exercisedb-aqui
RAPIDAPI_HOST=exercisedb.p.rapidapi.com

# ===========================
# ANTHROPIC API — Via Edge Function
# ===========================
# Configurar no Supabase (Backend)
# Dashboard Supabase → Functions → chat-ai → Settings → Secrets
ANTHROPIC_API_KEY=sk-ant-...sua-chave-aqui

# ===========================
# DESENVOLVIMENTO
# ===========================
ENVIRONMENT=development
DEBUG=false
